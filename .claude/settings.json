{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "NotebookEdit",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(py:*)",
      "Bash(ipython:*)",
      "Bash(jupyter:*)",
      "Bash(jupyter notebook:*)",
      "Bash(jupyter lab:*)",
      "Bash(jupyter nbconvert:*)",
      "Bash(jupyter execute:*)",
      "Bash(jupytext:*)",
      "Bash(papermill:*)",
      "Bash(nbstripout:*)",
      "Bash(pip:*)",
      "Bash(pip install:*)",
      "Bash(pip list)",
      "Bash(pip freeze)",
      "Bash(pip show:*)",
      "Bash(python -m:*)",
      "Bash(python -m pip:*)",
      "Bash(python -m venv:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m jupyter:*)",
      "Bash(python -m nbconvert:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(isort:*)",
      "Bash(mypy:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(where:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(bash skills.sh:*)",
      "Bash(./skills.sh:*)",
      "Skill(update-config)",
      "Skill(simplify)",
      "Skill(init)",
      "Skill(commit-commands:commit)",
      "Skill(commit-commands:commit-push-pr)",
      "Skill(review)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Edit(calidad-del-aire-datos-historicos-diarios.csv)",
      "Write(calidad-del-aire-datos-historicos-diarios.csv)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/credentials*)",
      "Read(**/*.key)"
    ],
    "ask": [
      "Bash(pip uninstall:*)",
      "Bash(jupyter nbconvert --inplace:*)",
      "Bash(papermill:*)"
    ]
  },
  "env": {
    "PYTHONIOENCODING": "utf-8",
    "JUPYTER_PLATFORM_DIRS": "1"
  }
}
